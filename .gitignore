logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Local backups / duplicates ────────────────
* 2.ts
* 2.js
* 2.tsx

# ── Misc ──────────────────────────────────────
*.local
.cache/
