# ── Dependencies ──────────────────────────────
node_modules/
backend/node_modules/

# ── Build output ──────────────────────────────
dist/
dist-ssr/
build/
.vite/
*.tsbuildinfo

# ── Secrets & credentials (NEVER commit) ──────
.env
.env.*
!.env.example
backend/.env
backend/.env.*
